{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.1/invariant-descriptor.schema.json",
  "title": "InvariantDescriptor",
  "type": "object",
  "required": ["id", "kind"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "enforcement": {
      "type": "string",
      "enum": ["declarative", "host", "runtime"],
      "default": "declarative"
    },
    "failure_behavior": {
      "type": "string",
      "enum": ["deny", "warn", "degrade"],
      "default": "deny"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
