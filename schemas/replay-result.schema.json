{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.1/replay-result.schema.json",
  "title": "ReplayResult",
  "type": "object",
  "required": [
    "correlation_id",
    "events",
    "event_count",
    "replayed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "https://chp.dev/schemas/v0.1/evidence-event.schema.json"
      }
    },
    "event_count": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean",
      "default": false,
      "description": "True when the result was capped by the host's replay limit. Use since_sequence to page through remaining events."
    },
    "replayed_at": {
      "type": "string",
      "format": "date-time"
    },
    "partial": {
      "type": "boolean",
      "default": false,
      "description": "True when a federated replay could not reach every member host - the timeline is incomplete and missing_hosts names the gaps. Never silently partial."
    },
    "missing_hosts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Member hosts that could not be reached during a federated replay."
    }
  }
}