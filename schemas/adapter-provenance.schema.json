{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.2/adapter-provenance.schema.json",
  "title": "AdapterProvenance",
  "description": "A publisher's signed claim that they built an exact adapter artifact (chp-v0.2.md section 9, proposal 0001). The signature covers the canonical header {kind, package, version, wheel_sha256, created_at, canonicalization}; the publisher's host-identity attestation (with optional anchors) rides inside, so 'who published this' resolves through the same trust roots as evidence bundles.",
  "type": "object",
  "required": [
    "kind",
    "package",
    "version",
    "wheel_sha256",
    "created_at",
    "canonicalization",
    "publisher",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "adapter-provenance"
    },
    "package": {
      "type": "string",
      "minLength": 1,
      "description": "Distribution name, e.g. chp-adapter-http."
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "wheel_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 of the artifact FILE - verifiable before anything executes. (The installed-RECORD fingerprint stays evidence-side: pip rewrites RECORD at install.)"
    },
    "created_at": {
      "type": "string"
    },
    "canonicalization": {
      "const": "chp-stable-v1"
    },
    "publisher": {
      "type": "object",
      "required": [
        "host_id",
        "public_key",
        "host_identity"
      ],
      "additionalProperties": false,
      "properties": {
        "host_id": {
          "type": "string"
        },
        "public_key": {
          "type": "string",
          "description": "base64 raw ed25519 public key"
        },
        "host_identity": {
          "type": "object",
          "description": "Self-signed host-identity attestation (chp-v0.2.md \u00a73). 'anchors' is omitted entirely when empty (\u00a73.1 byte rule).",
          "required": [
            "host_id",
            "public_key",
            "key_id",
            "valid_from",
            "signature"
          ],
          "additionalProperties": false,
          "properties": {
            "host_id": {
              "type": "string"
            },
            "public_key": {
              "type": "string"
            },
            "key_id": {
              "type": "string"
            },
            "valid_from": {
              "type": "string"
            },
            "valid_until": {
              "type": [
                "string",
                "null"
              ]
            },
            "anchors": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "description": "External trust roots vouching for this key, e.g. {\"type\":\"domain\",\"domain\":\"acme.example\"}. MUST be omitted when empty."
            },
            "signature": {
              "type": "string"
            }
          }
        },
        "key_history": {
          "type": "array",
          "description": "OPTIONAL rotation lineage (spec section 3.2 applied to publishers): continuity statements, each signed by the OLD key it names, so a verifier pinned to an earlier key can walk to the signing key. Omitted when empty. The history cannot self-vouch - the walk verifies each hop under the verifier's OWN pin.",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "required": [
        "algorithm",
        "key_id",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "key_id": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  }
}