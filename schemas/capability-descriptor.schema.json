{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.1/capability-descriptor.schema.json",
  "title": "CapabilityDescriptor",
  "type": "object",
  "required": ["id", "version", "description", "modes", "emits"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "Stable capability identity without transport location."
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "capability_uri": {
      "type": "string",
      "description": "Convenience form id:version. Descriptors may omit it if id and version are present."
    },
    "description": {
      "type": "string"
    },
    "name": {
      "type": ["string", "null"],
      "description": "Human-readable display name. Defaults to id when absent."
    },
    "category": {
      "type": ["string", "null"],
      "description": "Catalog taxonomy category (e.g. agent_operations, domain.crm). Use CapabilityCategory constants."
    },
    "provider": {
      "type": ["string", "null"],
      "description": "Identifier of the party or system that provides this capability."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "experimental", "certified", "deprecated"],
      "default": "draft",
      "description": "Capability maturity level per the CHP Capability Maturity Model."
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["sync", "async", "stream", "fire_and_forget"]
      }
    },
    "input_schema": {
      "type": "object",
      "description": "JSON Schema describing accepted payload shape.",
      "additionalProperties": true,
      "default": {}
    },
    "output_schema": {
      "type": "object",
      "description": "JSON Schema describing successful response data.",
      "additionalProperties": true,
      "default": {}
    },
    "idempotency": {
      "type": "string",
      "enum": ["required", "optional", "not_supported"],
      "default": "optional",
      "description": "Declared idempotency contract for this capability."
    },
    "side_effects": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Declared side effects (e.g. sends_email, writes_db, calls_external_api)."
    },
    "invariants": {
      "type": "array",
      "items": { "$ref": "#/$defs/InvariantDescriptor" },
      "default": []
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "low"
    },
    "emits": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Evidence event types the capability can emit."
    },
    "assurance": { "$ref": "#/$defs/AssuranceMetadata" },
    "owner": {
      "type": ["string", "null"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "host_requirements": {
      "$ref": "#/$defs/HostRequirements",
      "description": "Declared host-side compute, storage, inference, and locality requirements."
    },
    "policy": {
      "$ref": "#/$defs/PolicyDescriptor",
      "description": "Structured policy surface: risk tier, auth, approval, and data classification."
    }
  },
  "$defs": {
    "InvariantDescriptor": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "default": "" },
        "enforcement": {
          "type": "string",
          "enum": ["declarative", "host", "runtime"],
          "default": "declarative"
        },
        "failure_behavior": {
          "type": "string",
          "enum": ["deny", "warn", "degrade"],
          "default": "deny"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "AssuranceMetadata": {
      "type": "object",
      "required": ["level"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["S1", "S2", "S3"],
          "default": "S1"
        },
        "evidence_policy": {
          "type": "string",
          "default": "local-append-only"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "HostRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "compute":   { "type": ["string", "null"] },
        "storage":   { "type": ["string", "null"] },
        "inference": { "type": ["string", "null"] },
        "runtime":   { "type": ["string", "null"] },
        "network":   { "type": ["string", "null"] },
        "isolation": { "type": ["string", "null"] },
        "locality": {
          "type": "string",
          "enum": ["local", "edge", "cloud", "hybrid", "any"],
          "default": "any"
        }
      }
    },
    "PolicyDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk_tier": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "default": "low"
        },
        "auth_required":      { "type": "boolean", "default": false },
        "approval_required":  { "type": "boolean", "default": false },
        "data_classification": { "type": ["string", "null"] },
        "allowed_actors": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  }
}
