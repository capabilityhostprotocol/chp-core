{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.2/task-bundle.schema.json",
  "title": "TaskBundle",
  "description": "Cross-host verification unit (chp-v0.2.md \u00a78): one correlation's per-host signed bundles, canonically ordered, with a root-of-roots fingerprint.",
  "type": "object",
  "required": [
    "kind",
    "correlation_id",
    "created_at",
    "protocol_version",
    "canonicalization",
    "assurance",
    "bundles",
    "task_root_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "task-bundle"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string",
      "enum": [
        "0.2"
      ]
    },
    "canonicalization": {
      "type": "string"
    },
    "assurance": {
      "type": "string",
      "enum": [
        "none",
        "hash-chain",
        "signed"
      ],
      "description": "MINIMUM member tier \u2014 degradation surfaced, never hidden."
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://chp.dev/schemas/v0.2/evidence-bundle.schema.json"
      },
      "description": "Per-host bundles, byte-untouched, sorted by (host_id, root_hash)."
    },
    "task_root_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA256 over member root_hashes joined by \\n."
    }
  }
}
