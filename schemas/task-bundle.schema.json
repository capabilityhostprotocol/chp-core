{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chp.dev/schemas/v0.2/task-bundle.schema.json",
  "title": "TaskBundle",
  "description": "Cross-host verification unit (chp-v0.2.md \u00a78): one correlation's per-host signed bundles, canonically ordered, with a root-of-roots fingerprint.",
  "type": "object",
  "required": [
    "kind",
    "correlation_id",
    "created_at",
    "protocol_version",
    "canonicalization",
    "assurance",
    "bundles",
    "task_root_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "task-bundle"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string",
      "enum": [
        "0.2"
      ]
    },
    "canonicalization": {
      "type": "string"
    },
    "assurance": {
      "type": "string",
      "enum": [
        "none",
        "hash-chain",
        "signed"
      ],
      "description": "MINIMUM member tier \u2014 degradation surfaced, never hidden."
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://chp.dev/schemas/v0.2/evidence-bundle.schema.json"
      },
      "description": "Per-host bundles, byte-untouched, sorted by (host_id, root_hash)."
    },
    "task_root_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA256 over member root_hashes joined by \\n."
    },
    "aggregator": {
      "type": "object",
      "description": "Optional aggregator signature (the `aggregated` layer): the assembling gateway signs the canonical task-bundle header with its own key + attestation. Omit-when-empty - an unsigned task bundle is byte-identical to the pre-aggregator format.",
      "required": [
        "host_id",
        "public_key",
        "host_identity",
        "signature"
      ],
      "properties": {
        "host_id": {
          "type": "string"
        },
        "public_key": {
          "type": "string",
          "description": "base64 raw ed25519 public key"
        },
        "host_identity": {
          "type": "object",
          "description": "Self-signed host-identity attestation (chp-v0.2.md \u00a73). 'anchors' is omitted entirely when empty (\u00a73.1 byte rule).",
          "required": [
            "host_id",
            "public_key",
            "key_id",
            "valid_from",
            "signature"
          ],
          "additionalProperties": false,
          "properties": {
            "host_id": {
              "type": "string"
            },
            "public_key": {
              "type": "string"
            },
            "key_id": {
              "type": "string"
            },
            "valid_from": {
              "type": "string"
            },
            "valid_until": {
              "type": [
                "string",
                "null"
              ]
            },
            "anchors": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "description": "External trust roots vouching for this key, e.g. {\"type\":\"domain\",\"domain\":\"acme.example\"}. MUST be omitted when empty."
            },
            "signature": {
              "type": "string"
            }
          }
        },
        "signature": {
          "type": "object",
          "required": [
            "algorithm",
            "key_id",
            "signature"
          ],
          "properties": {
            "algorithm": {
              "const": "ed25519"
            },
            "key_id": {
              "type": "string"
            },
            "signature": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}